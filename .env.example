GOOGLE_API_KEY=
# Padrão no código: gemini-embedding-001 (3072 dims). models/embedding-001 → 768 (ajuste GOOGLE_EMBEDDING_DIM).
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
# Só necessário se usar modelo legacy ou dimensão não padrão (ex.: 768 para models/embedding-001).
# GOOGLE_EMBEDDING_DIM=3072

# Free tier / 429: use true para embeddings sequenciais (embed_content por texto) em vez do batch do SDK.
# Quando ativo, EMBED_BATCH_DELAY_SECONDS também é a pausa entre cada texto dentro do lote.
GOOGLE_EMBED_SEQUENTIAL=false

# Ingest: tamanho do lote ao gravar no PGVector (padrão 14) e pausa em segundos entre lotes (padrão 2).
# Com GOOGLE_EMBED_SEQUENTIAL=true, aumente EMBED_BATCH_DELAY_SECONDS (ex.: 15–30) para reduzir 429.
EMBED_BATCH_SIZE=14
EMBED_BATCH_DELAY_SECONDS=2

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DATABASE_URL=
# Obrigatório — mesmo nome de collection usado no ingest e na busca (search).
PG_VECTOR_COLLECTION_NAME=
PDF_PATH=
